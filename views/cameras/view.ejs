<%- include('../partials/header') %>

<div id="cameraViewContent">Loading...</div>

<%- include('../partials/footer') %>

<script src="/js/stream-viewer.js"></script>
<script src="/js/ptz-controls.js"></script>
<script>
  const cameraId = '<%= cameraId %>';
  const USER_ROLE = '<%= user.role %>';
  let camera = null;
  let viewer = null;

  async function loadCamera() {
    try {
      camera = await api('/api/cameras/' + cameraId);
      renderView();
    } catch (err) {
      document.getElementById('cameraViewContent').innerHTML =
        '<div class="card" style="text-align:center;padding:40px;color:var(--danger);">Failed to load camera: ' + err.message + '</div>';
    }
  }

  function renderView() {
    const c = camera;
    const canControl = USER_ROLE !== 'viewer';

    let controlBtns = '';
    if (canControl) {
      controlBtns = '<button class="btn btn-danger" id="recordBtn" onclick="toggleRecording()">\u23FA Record</button>' +
        '<button class="btn btn-outline" onclick="captureSnapshot()">\uD83D\uDCF8 Snapshot</button>';
    }

    let ptzHtml = '';
    if (c.ptz_supported && canControl) {
      ptzHtml = '<div id="ptzPanel" class="card"><div class="card-header"><span class="card-title">PTZ Control</span></div><div id="ptzContainer"></div></div>';
    }

    const container = document.getElementById('cameraViewContent');
    container.innerHTML =
      '<div style="display:flex;gap:20px;flex-wrap:wrap;">' +
        '<div style="flex:2;min-width:400px;">' +
          '<div class="camera-preview" style="border-radius:var(--radius);overflow:hidden;">' +
            '<canvas id="streamCanvas" style="width:100%;height:auto;aspect-ratio:16/9;background:#000;display:block;"></canvas>' +
          '</div>' +
          '<div style="display:flex;gap:8px;margin-top:12px;flex-wrap:wrap;">' +
            '<button class="btn btn-primary" id="playBtn" onclick="toggleStream()">\u25B6 Play</button>' +
            '<button class="btn btn-outline" onclick="enterFullscreen()">\u26F6 Fullscreen</button>' +
            controlBtns +
          '</div>' +
        '</div>' +
        '<div style="flex:1;min-width:280px;">' +
          '<div class="card" style="margin-bottom:16px;">' +
            '<div class="card-header"><span class="card-title">Camera Info</span></div>' +
            '<table style="width:100%;">' +
              '<tr><td style="color:var(--text-secondary);width:100px;">Name</td><td>' + esc(c.name) + '</td></tr>' +
              '<tr><td style="color:var(--text-secondary);">Status</td><td><span class="status-dot ' + c.status + '"></span>' + c.status + '</td></tr>' +
              '<tr><td style="color:var(--text-secondary);">Location</td><td>' + esc(c.location || '-') + '</td></tr>' +
              '<tr><td style="color:var(--text-secondary);">Group</td><td>' + esc(c.group_name || '-') + '</td></tr>' +
              '<tr><td style="color:var(--text-secondary);">RTSP</td><td style="font-size:11px;word-break:break-all;">' + esc(c.rtsp_url) + '</td></tr>' +
              '<tr><td style="color:var(--text-secondary);">PTZ</td><td>' + (c.ptz_supported ? 'Supported' : 'Not supported') + '</td></tr>' +
              '<tr><td style="color:var(--text-secondary);">Last Seen</td><td>' + (c.last_seen_at ? formatDate(c.last_seen_at) : '-') + '</td></tr>' +
            '</table>' +
          '</div>' +
          ptzHtml +
        '</div>' +
      '</div>';

    if (c.ptz_supported && canControl) {
      initPtzControls('ptzContainer', cameraId);
    }
  }

  function esc(s) {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  let isStreaming = false;
  function toggleStream() {
    const canvas = document.getElementById('streamCanvas');
    const btn = document.getElementById('playBtn');
    if (isStreaming) {
      if (viewer) viewer.stop();
      isStreaming = false;
      btn.textContent = '\u25B6 Play';
    } else {
      viewer = new StreamViewer(canvas, cameraId);
      viewer.start();
      isStreaming = true;
      btn.textContent = '\u23F9 Stop';
    }
  }

  let isRecording = false;
  async function toggleRecording() {
    const btn = document.getElementById('recordBtn');
    try {
      if (isRecording) {
        await api('/api/recordings/stop', { method: 'POST', body: JSON.stringify({ camera_id: cameraId }) });
        isRecording = false;
        btn.textContent = '\u23FA Record';
        btn.classList.remove('btn-success');
        btn.classList.add('btn-danger');
        notify('Recording stopped', 'info');
      } else {
        await api('/api/recordings/start', { method: 'POST', body: JSON.stringify({ camera_id: cameraId }) });
        isRecording = true;
        btn.textContent = '\u23F9 Stop Recording';
        btn.classList.remove('btn-danger');
        btn.classList.add('btn-success');
        notify('Recording started', 'success');
      }
    } catch (err) {
      notify(err.message, 'error');
    }
  }

  async function captureSnapshot() {
    try {
      await api('/api/snapshots/capture/' + cameraId, { method: 'POST' });
      notify('Snapshot captured', 'success');
    } catch (err) {
      notify(err.message, 'error');
    }
  }

  function enterFullscreen() {
    const canvas = document.getElementById('streamCanvas');
    if (canvas.requestFullscreen) canvas.requestFullscreen();
    else if (canvas.webkitRequestFullscreen) canvas.webkitRequestFullscreen();
  }

  loadCamera();
</script>
