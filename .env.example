# Server
PORT=3000
HOST=0.0.0.0

# Authentication
JWT_SECRET=change-this-to-a-random-secret-key
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
DEFAULT_ADMIN_PASSWORD=admin123

# Database
DB_PATH=./data/camera.db

# Storage
RECORDINGS_DIR=./data/recordings
SNAPSHOTS_DIR=./data/snapshots
MAX_STORAGE_GB=100
RECORDING_RETENTION_DAYS=30
SNAPSHOT_RETENTION_DAYS=7

# FFmpeg
FFMPEG_PATH=ffmpeg

# Stream defaults
STREAM_RESOLUTION=1024x768
STREAM_BITRATE=1000k
STREAM_FPS=30

# Motion Detection
MOTION_SENSITIVITY=medium
MOTION_COOLDOWN_SECONDS=60

# SMTP (for email alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=camera-alerts@localhost

# Webhook (for alert notifications)
WEBHOOK_URL=
